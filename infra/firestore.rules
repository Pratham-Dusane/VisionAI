rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOrgMember(orgId) {
      return signedIn()
        && exists(/databases/$(database)/documents/organizations/$(orgId))
        && request.auth.uid in get(/databases/$(database)/documents/organizations/$(orgId)).data.members;
    }

    function isOrgOwner(orgId) {
      return signedIn()
        && exists(/databases/$(database)/documents/organizations/$(orgId))
        && request.auth.uid == get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId;
    }

    function canReadOrgScoped(data) {
      return signedIn()
        && (
          (data.keys().hasAny(['orgId']) && isOrgMember(data.orgId))
          || (data.keys().hasAny(['org_id']) && isOrgMember(data.org_id))
        );
    }

    match /organizations/{orgId} {
      allow create: if signedIn()
        && request.resource.data.ownerId == request.auth.uid
        && request.resource.data.members is list
        && request.auth.uid in request.resource.data.members;
      allow read: if signedIn() && request.auth.uid in resource.data.members;
      allow update: if isOrgOwner(orgId);
      allow delete: if false;
    }

    match /audits/{auditId} {
      allow read: if canReadOrgScoped(resource.data);
      allow create, update, delete: if false;

      match /narratives/{narrativeId} {
        allow read: if canReadOrgScoped(get(/databases/$(database)/documents/audits/$(auditId)).data);
        allow create, update, delete: if false;
      }
    }

    match /drift_batches/{batchId} {
      allow read: if canReadOrgScoped(resource.data);
      allow create, update, delete: if false;
    }

    match /notifications/{notificationId} {
      allow read: if canReadOrgScoped(resource.data);
      allow update: if canReadOrgScoped(resource.data)
        && request.resource.data.diff(resource.data).changedKeys().hasOnly(['read', 'readAt'])
        && request.resource.data.read == true;
      allow create, delete: if false;
    }

    match /sector_benchmarks/{benchmarkId} {
      allow read: if signedIn() && resource.data.opt_in == true;
      allow create, update, delete: if false;
    }

    match /org_api_keys/{keyId} {
      allow read, write: if false;
    }

    // Regulations collection - read-only for all authenticated users
    match /regulations/{regulationId} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    // Regulatory alerts - org-scoped
    match /regulatory_alerts/{alertId} {
      allow read: if canReadOrgScoped(resource.data);
      allow create, update, delete: if false;
    }

    // System collection - read-only for authenticated users
    match /system/{docId} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
